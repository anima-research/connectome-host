ANTHROPIC_API_KEY=sk-ant-...
# MODEL=claude-opus-4-6

# --- Zulip (clerk + miner) -----------------------------------------------
# Zulip auth is via .zuliprc file (not env vars). Download from:
#   Zulip > Settings > Your Bots > download .zuliprc
# Place it at the repo root as .zuliprc (already gitignored).

# Channel the clerk staffs and the triumvirate uses for communication
# ZULIP_CHANNEL=your-channel-name

# --- Recipe ${VAR} substitutions ---------------------------------------
# Recipes in recipes/ reference these via ${VAR}.  Unset = that branch of
# the recipe fails to load; remove the referencing mcpServers block from
# the recipe if you don't use the source.

# GitLab (knowledge-miner.json: gitlab)
# GITLAB_TOKEN=glpat-...
# GITLAB_API_URL=https://gitlab.example.com/api/v4

# Notion (knowledge-miner.json: syncntn)
# NOTION_STORAGE_URL=http://localhost:8000
# NOTION_WORKSPACE_ID=...

# Scribe (knowledge-miner.json: scribe)
# GEMINI_API_KEY=your-gemini-api-key
# NOTION_API_KEY=your-notion-integration-token
# SCRIBE_GLOSSARY_URL=http://your-wiki/wiki/index.php/Glossary_Page
